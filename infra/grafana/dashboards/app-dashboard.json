{
  "uid": "app-main",
  "title": "요즘마켓 — 앱 관측",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP p99 지연 (URI별)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le, uri) (rate(http_server_requests_seconds_bucket[1m])))",
          "legendFormat": "p99 {{uri}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum by (le, uri) (rate(http_server_requests_seconds_bucket[1m])))",
          "legendFormat": "p50 {{uri}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "처리량 (req/s, URI별)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "5xx 에러율 (req/s)",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[1m]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "DB 커넥션 풀 (HikariCP)",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (instance) (hikaricp_connections_active)", "legendFormat": "active {{instance}}" },
        { "refId": "B", "expr": "sum by (instance) (hikaricp_connections_pending)", "legendFormat": "대기 {{instance}}" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "JVM Heap 사용량",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (instance) (jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "heap {{instance}}" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "프로세스 CPU",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "process_cpu_usage", "legendFormat": "cpu {{instance}}" }
      ]
    }
  ]
}
